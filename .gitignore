companion/.usage.json
companion/.dashboard.json
# media-generation spend ledger (code-enforced monthly cap state)
scripts/.media-usage.json
# control-plane event store (system of record — local runtime data) + eval results
control-plane/data/
evals/.results.json
# companion-generated images (work product, regenerated)
companion/public/_generated/
# offline Vosk wake model (~41MB binary — download via scripts/get-vosk-model.mjs)
companion/public/models/
# netlify CLI local link state
.netlify/
# inbox audit/unsubscribe reports contain personal sender lists — keep them local
reports/
# Jarvis World build output + PWA artifacts (regenerated by `vite build`)
jarvis-world/dist/
jarvis-world/dev-dist/
# Docker bind-mount volumes created on the NAS at runtime
volumes/
# local dev tooling (preview launch config, scheduler runtime state)
.claude/
control-plane/data/
# Gov proposal drafts (work product; may contain entity details) — regenerated by the gov worker
gov-drafts/
desktop/dist/
# encrypted secrets vault (never commit)
control-plane/vault.enc
