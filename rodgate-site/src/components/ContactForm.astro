---
// Netlify Forms — static-friendly. Submissions notify vinicio@rodgategroup.com
// (configure the notification email in the Netlify dashboard → Forms).
import Icon from './Icon.astro';
---
<form
  name="capability-briefing"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  action="/contact/thanks"
  class="card p-6 md:p-8"
>
  <input type="hidden" name="form-name" value="capability-briefing" />
  <p hidden>
    <label>Don't fill this out: <input name="bot-field" /></label>
  </p>

  <div class="grid gap-5 sm:grid-cols-2">
    <label class="block">
      <span class="text-sm font-semibold text-fg">Name <span class="text-destructive">*</span></span>
      <input type="text" name="name" required autocomplete="name"
        class="mt-1.5 w-full rounded-[var(--r-md)] border border-border bg-[var(--color-bg)] px-3.5 py-2.5 text-fg placeholder:text-muted-fg/70 focus:border-primary" />
    </label>
    <label class="block">
      <span class="text-sm font-semibold text-fg">Organization</span>
      <input type="text" name="organization" autocomplete="organization"
        class="mt-1.5 w-full rounded-[var(--r-md)] border border-border bg-[var(--color-bg)] px-3.5 py-2.5 text-fg placeholder:text-muted-fg/70 focus:border-primary" />
    </label>
    <label class="block">
      <span class="text-sm font-semibold text-fg">Email <span class="text-destructive">*</span></span>
      <input type="email" name="email" required autocomplete="email"
        class="mt-1.5 w-full rounded-[var(--r-md)] border border-border bg-[var(--color-bg)] px-3.5 py-2.5 text-fg placeholder:text-muted-fg/70 focus:border-primary" />
    </label>
    <label class="block">
      <span class="text-sm font-semibold text-fg">Requirement type</span>
      <select name="requirement"
        class="mt-1.5 w-full rounded-lg border border-border bg-bg px-3.5 py-2.5 text-fg focus:border-primary">
        <option>Custodial & Janitorial</option>
        <option>Grounds & Landscaping</option>
        <option>Trash & Haul-Away</option>
        <option>Facilities Support</option>
        <option>Subcontracting / teaming</option>
        <option>Other</option>
      </select>
    </label>
  </div>

  <label class="mt-5 block">
    <span class="text-sm font-semibold text-fg">Message</span>
    <textarea name="message" rows="5"
      placeholder="Tell us about the requirement, location, and timeline."
      class="mt-1.5 w-full rounded-[var(--r-md)] border border-border bg-[var(--color-bg)] px-3.5 py-2.5 text-fg placeholder:text-muted-fg/70 focus:border-primary"></textarea>
  </label>

  <button type="submit" class="btn btn-gold mt-6">
    Send request <Icon name="arrow-right" size={17} />
  </button>
</form>
