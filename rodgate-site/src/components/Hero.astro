---
import Icon from './Icon.astro';
import { company } from '../data/company.js';
// Photo-free by design: a deliberate dark editorial hero — layered navy,
// a soft directional glow, and an engraved shield/blueprint motif.
---
<section class="hero">
  <div class="hero__art" aria-hidden="true">
    <svg viewBox="0 0 760 760" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="hg" width="38" height="38" patternUnits="userSpaceOnUse">
          <path d="M38 0H0V38" stroke="#88a4e0" stroke-opacity=".07" stroke-width="1"/>
        </pattern>
        <linearGradient id="hgold" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color="#d3a862" stop-opacity=".6"/>
          <stop offset="1" stop-color="#6f95e6" stop-opacity=".1"/>
        </linearGradient>
        <radialGradient id="hglow" cx="62%" cy="30%" r="55%">
          <stop offset="0" stop-color="#2b4a9e" stop-opacity=".55"/>
          <stop offset="1" stop-color="#2b4a9e" stop-opacity="0"/>
        </radialGradient>
      </defs>
      <rect width="760" height="760" fill="url(#hg)"/>
      <rect width="760" height="760" fill="url(#hglow)"/>
      <g stroke="url(#hgold)" stroke-width="1.25" fill="none">
        <circle cx="520" cy="360" r="250"/>
        <circle cx="520" cy="360" r="196"/>
        <circle cx="520" cy="360" r="142"/>
      </g>
      <g stroke="#d3a862" stroke-opacity=".55" stroke-width="1.5" fill="none">
        <path d="M520 158 L682 254 V420 C682 512 604 558 520 592 C436 558 358 512 358 420 V254 Z"/>
      </g>
      <path d="M472 360 l34 34 l72 -76" stroke="#d3a862" stroke-opacity=".9" stroke-width="3.5"
        stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      <g stroke="#88a4e0" stroke-opacity=".2" stroke-width="1.25">
        <path d="M520 96 v30 M520 596 v30 M258 360 h30 M752 360 h-30"/>
      </g>
    </svg>
  </div>

  <div class="container hero__inner">
    <p class="hero__eyebrow">Federal · State · Local Facilities Services</p>
    <h1 class="display hero__title">
      Facilities kept clean, secure, and <span class="hero__accent">mission-ready.</span>
    </h1>
    <p class="hero__lead">
      {company.legalName} (DBA {company.dba}) is a self-certified Small Disadvantaged,
      Minority-Owned (Hispanic American) small business delivering custodial, grounds,
      haul-away, and facilities support to government — with the accountability of an
      owner-managed firm.
    </p>
    <div class="hero__cta">
      <a href="/contact" class="hero__pill">Request a Capability Briefing <Icon name="arrow-right" size={18} /></a>
      <a href="/capabilities" class="hero__ghost">View company data <Icon name="arrow-right" size={16} /></a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative; isolation: isolate;
    display: flex; align-items: center;
    min-height: clamp(520px, 76vh, 780px);
    overflow: hidden; color: #fff;
    background: linear-gradient(150deg, #12295c 0%, var(--ink) 56%, #050b18 100%);
  }
  .hero__art {
    position: absolute; inset: 0 -4% 0 auto; width: min(64%, 780px); z-index: -1;
    mask-image: linear-gradient(90deg, transparent, #000 46%);
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 46%);
  }
  .hero__art svg { width: 100%; height: 100%; }

  .hero__inner { padding-block: clamp(56px, 9vw, 96px); max-width: 760px; }
  .hero__eyebrow {
    font-family: 'Lexend', sans-serif; font-size: 12.5px; font-weight: 600;
    letter-spacing: 0.2em; text-transform: uppercase; color: rgba(234,240,251,.72);
    margin: 0 0 22px; padding-left: 34px; position: relative;
  }
  .hero__eyebrow::before { content: ''; position: absolute; left: 0; top: 50%; width: 24px; height: 2px; background: var(--gold-line); }

  .hero__title { max-width: 16ch; color: #fff; margin: 0; }
  .hero__accent { color: var(--gold-line); }
  .hero__lead { margin: 26px 0 0; max-width: 56ch; font-size: clamp(1.05rem, 1.4vw, 1.24rem); line-height: 1.6; color: rgba(234,240,251,.85); }

  .hero__cta { margin-top: 38px; display: flex; flex-wrap: wrap; align-items: center; gap: 12px 22px; }
  .hero__pill {
    display: inline-flex; align-items: center; gap: 10px;
    background: #fff; color: var(--ink);
    font-family: 'Lexend', sans-serif; font-weight: 600; font-size: 15px;
    padding: 15px 26px; border-radius: 999px;
    transition: transform .18s ease, box-shadow .18s ease;
  }
  .hero__pill:hover { transform: translateY(-2px); box-shadow: 0 16px 40px rgba(0,0,0,.35); }
  .hero__ghost {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: 'Lexend', sans-serif; font-weight: 500; font-size: 15px; color: #fff;
    padding: 8px 4px; border-bottom: 1px solid transparent; transition: border-color .18s ease;
  }
  .hero__ghost:hover { border-color: var(--gold-line); }

  @media (max-width: 700px) {
    .hero__art { width: 96%; opacity: .55; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__pill:hover { transform: none; }
  }
</style>
