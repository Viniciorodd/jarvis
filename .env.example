# Copy to .env and fill in. NEVER commit .env.

# --- Clock (WHEN Jarvis talks to you) ---
# Container timezone for control-plane + scheduler + telegram-bridge. Docker containers default to
# UTC, which made schedule.json at_hour:8 fire at 08:00 UTC = 4 AM ET — every scheduled Telegram
# landed at dawn. With TZ set, at_hour and working_hours mean TRUE local (Eastern) hours.
# Compose defaults this to America/New_York even if unset; activates on the next NAS redeploy.
TZ=America/New_York

# --- Brain ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Telegram command center (create bot via @BotFather, get chat id via @userinfobot) ---
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=123456789

# --- Gov contracting ---
# Free key: https://sam.gov → account → API key (also works for api.sam.gov opportunities)
SAM_API_KEY=

# --- Memory ---
NOTION_API_KEY=ntn_...

# --- Vault (Obsidian "Second Brain") — source of truth for tasks (control-plane/tasks.mjs) ---
# The cockpit reads/writes Markdown task checkboxes here. Defaults to ~/Documents/Second Brain.
VAULT_DIR=C:\Users\you\Documents\Second Brain

# --- Companion file areas (semicolon-separated; what Jarvis may organize) ---
# Local workspace + NAS shares. NAS paths need the shares mounted/authenticated on the PC.
JARVIS_ROOTS=C:\Users\you\Desktop\JARVIS-Workspace;\\192.168.6.121\BusinessVault;\\192.168.6.121\PersonalVault

# --- Companion voice ---
# FREE local voice (default): Kokoro runs offline with NO key + NO monthly fee (scripts/tts-kokoro.py).
#   one-time: pip install kokoro-onnx soundfile  + download kokoro-v1.0.onnx & voices-v1.0.bin to repo root.
# /api/tts order: local Kokoro → ElevenLabs (if key) → browser. TTS_PROVIDER = auto | local | eleven.
TTS_PROVIDER=auto
KOKORO_TTS_URL=http://127.0.0.1:8880/tts
KOKORO_VOICE=af_heart
# ElevenLabs (OPTIONAL premium): https://elevenlabs.io → Profile → API key. Leave blank to stay 100% free.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
# Deepgram speech-to-text: https://deepgram.com → API Keys
DEEPGRAM_API_KEY=

# --- Google: let the companion READ your Gmail + Calendar (read-only) ---
# One-time setup in docs/google-setup.md: create a "Desktop app" OAuth client, enable Gmail + Calendar
# APIs, paste the id/secret below, then run:  node scripts/google-auth.mjs  (it fills GOOGLE_REFRESH_TOKEN).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Gmail app passwords (gov email send + Hector reading subcontractor replies over IMAP) ---
# GOV WORK USES ONLY THE RODGATE MAILBOX. Make a 16-char App Password (Google acct → Security → App
# passwords, 2-Step Verification on). Used by scripts/gov-send.mjs (send) + pods/gov/replies.mjs (read).
RODGATE_GMAIL_USER=rodgategroup@gmail.com
RODGATE_GMAIL_APP_PASSWORD=
# Approve-to-send — the operator EXPLICITLY enabled this 2026-07-12: with GOV_AUTO_SEND=1, approving
# a send gate on Telegram/HQ/cockpit REALLY SENDS the email. The gate is still the control: nothing
# sends without a human tap (doctrine §9 rule 2 — send/submit/spend ALWAYS gate first). Unset or 0 =
# approvals dry-run (log + preview only). Set GOV_AUTO_SEND=1 on BOTH the PC .env and the NAS .env.
GOV_AUTO_SEND=1
# Personal mailbox — inbox-cleanup tooling only, NEVER gov:
PERSONAL_GMAIL_USER=
PERSONAL_GMAIL_APP_PASSWORD=

# --- Sub discovery (Hector finds local businesses → CRM) ---
# Google Places: in the SAME Google Cloud project, enable "Places API" → Credentials → API key.
GOOGLE_PLACES_API_KEY=
# (SAM.gov entity discovery reuses SAM_API_KEY above.)

# --- Slack command center (see docs/voice-and-comms-setup.md) ---
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_APPROVALS_CHANNEL=#approvals

# --- HQ dashboard ---
HQ_PORT=8099
# Optional shared secret. If set, POSTs to the HQ API need header: Authorization: Bearer <token>
HQ_TOKEN=
# Base URL n8n/pods use to reach HQ from inside Docker (service name, not localhost)
HQ_URL=http://hq:8099

# --- Control plane + Chief-of-Staff router (the spine) ---
CONTROL_PLANE_PORT=8787
# Base URL pods/scheduler use to reach the control-plane (service name inside Docker)
CONTROL_PLANE_URL=http://control-plane:8787
# Code-enforced spend caps (deterministic gate, doctrine #1) — dollars
SPEND_ACTION_CAP_USD=2
SPEND_DAILY_CAP_USD=5
# Model tiers — the CLAUDE model used at each tier when Claude is the chosen brain. COS_MODEL overrides
# the router's classifier model. (The free-compute layer below decides WHICH provider answers.)
COS_MODEL=claude-haiku-4-5
MODEL_CHEAP=claude-haiku-4-5
MODEL_DRAFT=claude-sonnet-4-6
MODEL_REFLECT=claude-opus-4-8

# --- Free compute layer (model-router): Jarvis never goes dark when Claude tokens run out ---
# Every LLM call routes through pods/model-router.mjs: local Ollama → OpenRouter (free) → Claude.
# LLM_PREFER sets the default brain: auto (free-first, falls back) | local | openrouter | claude.
# The companion's brain chip writes a runtime override to control-plane/brain-mode.json (it wins over this).
LLM_PREFER=auto
# Local models via Ollama (free, private, on the PC's GPU). OpenAI-compatible API auto-serves here.
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_AUTOSTART=1
# OLLAMA_BIN=ollama   # path/name of the ollama binary if not on PATH
LOCAL_MODEL=qwen3.6
LOCAL_MODEL_FAST=gemma4
# OpenRouter: one key → many models, incl. FREE ":free" slugs. Get a key at openrouter.ai → Keys.
# (You may need to enable free-model data sharing in OpenRouter privacy settings for :free models.)
OPENROUTER_API_KEY=
# Free model slug (OpenRouter rotates these — check openrouter.ai/models for current ":free" ids).
# Free models are RATE-LIMITED per account (~50 req/day on a $0 balance; ~1000/day after a one-time $10 credit).
OPENROUTER_MODEL_FREE=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_MODEL_CHEAP=   # optional better paid model for draft/reflect when on OpenRouter; defaults to the free one
# Scheduler: how often to re-evaluate due jobs (ms). Optional cheap "is there work?" hook for poll jobs.
SCHEDULER_TICK_MS=900000
JOB_CHECK_URL=

# --- n8n / Postgres ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me-long-random
POSTGRES_DB=n8n
N8N_ENCRYPTION_KEY=change-me-long-random
GENERIC_TIMEZONE=America/New_York
# Your NAS's Tailscale hostname. With the tailscale container's hostname "jarvis-nas"
# + MagicDNS on, this is simply: jarvis-nas
N8N_HOST=jarvis-nas

# --- Tailscale (only if running it as the Docker container, not the host app) ---
# Auth key from https://login.tailscale.com/admin/settings/keys (Generate auth key).
# Reusable OFF, Ephemeral OFF (we persist state in ./volumes/tailscale).
TS_AUTHKEY=tskey-auth-...

# --- Langfuse (OPTIONAL visual tracing, doctrine §11) — see docs/langfuse.md ---
# Leave unset and tracing is a silent no-op (the JSONL event log is the source of truth either way).
# Set all three (after deploying the Langfuse container) to mirror every event into Langfuse.
# LANGFUSE_HOST=http://langfuse:3000
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
