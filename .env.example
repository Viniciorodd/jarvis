# Copy to .env and fill in. NEVER commit .env.

# --- Brain ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Telegram command center (create bot via @BotFather, get chat id via @userinfobot) ---
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=123456789

# --- Gov contracting ---
# Free key: https://sam.gov → account → API key (also works for api.sam.gov opportunities)
SAM_API_KEY=

# --- Memory ---
NOTION_API_KEY=ntn_...

# --- Companion file areas (semicolon-separated; what Jarvis may organize) ---
# Local workspace + NAS shares. NAS paths need the shares mounted/authenticated on the PC.
JARVIS_ROOTS=C:\Users\you\Desktop\JARVIS-Workspace;\\192.168.6.121\BusinessVault;\\192.168.6.121\PersonalVault

# --- Companion voice (optional — without it she uses free browser voice) ---
# ElevenLabs: https://elevenlabs.io → Profile → API key. Pick a voice ID in their Voice Library.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
# Deepgram speech-to-text: https://deepgram.com → API Keys
DEEPGRAM_API_KEY=

# --- Google: let the companion READ your Gmail + Calendar (read-only) ---
# One-time setup in docs/google-setup.md: create a "Desktop app" OAuth client, enable Gmail + Calendar
# APIs, paste the id/secret below, then run:  node scripts/google-auth.mjs  (it fills GOOGLE_REFRESH_TOKEN).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Slack command center (see docs/voice-and-comms-setup.md) ---
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_APPROVALS_CHANNEL=#approvals

# --- HQ dashboard ---
HQ_PORT=8099
# Optional shared secret. If set, POSTs to the HQ API need header: Authorization: Bearer <token>
HQ_TOKEN=
# Base URL n8n/pods use to reach HQ from inside Docker (service name, not localhost)
HQ_URL=http://hq:8099

# --- Control plane + Chief-of-Staff router (the spine) ---
CONTROL_PLANE_PORT=8787
# Base URL pods/scheduler use to reach the control-plane (service name inside Docker)
CONTROL_PLANE_URL=http://control-plane:8787
# Code-enforced spend caps (deterministic gate, doctrine #1) — dollars
SPEND_ACTION_CAP_USD=2
SPEND_DAILY_CAP_USD=5
# Model tiers — conservative (all Haiku) to start. Point any tier at local Ollama later to cut cost,
# e.g. MODEL_CHEAP=ollama/llama3.1 (free, on the NAS). COS_MODEL overrides the router's classifier model.
COS_MODEL=claude-haiku-4-5
MODEL_CHEAP=claude-haiku-4-5
MODEL_DRAFT=claude-haiku-4-5
MODEL_REFLECT=claude-haiku-4-5
# Scheduler: how often to re-evaluate due jobs (ms). Optional cheap "is there work?" hook for poll jobs.
SCHEDULER_TICK_MS=900000
JOB_CHECK_URL=

# --- n8n / Postgres ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me-long-random
POSTGRES_DB=n8n
N8N_ENCRYPTION_KEY=change-me-long-random
GENERIC_TIMEZONE=America/New_York
# Your NAS's Tailscale hostname. With the tailscale container's hostname "jarvis-nas"
# + MagicDNS on, this is simply: jarvis-nas
N8N_HOST=jarvis-nas

# --- Tailscale (only if running it as the Docker container, not the host app) ---
# Auth key from https://login.tailscale.com/admin/settings/keys (Generate auth key).
# Reusable OFF, Ephemeral OFF (we persist state in ./volumes/tailscale).
TS_AUTHKEY=tskey-auth-...
