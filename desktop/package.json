{
  "name": "jarvis-desktop",
  "version": "1.0.0",
  "description": "JARVIS — unified desktop app (Jarvis World + HQ) for Windows & macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.rodgate.jarvis",
    "productName": "Jarvis",
    "files": ["main.js", "shell.html", "icon.*"],
    "win": { "target": "nsis" },
    "mac": { "target": "dmg", "category": "public.app-category.productivity" },
    "linux": { "target": "AppImage" }
  }
}
