# Copy to .env and fill in. NEVER commit .env.

# --- Brain ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Telegram command center (create bot via @BotFather, get chat id via @userinfobot) ---
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=123456789

# --- Gov contracting ---
# Free key: https://sam.gov → account → API key (also works for api.sam.gov opportunities)
SAM_API_KEY=

# --- Memory ---
NOTION_API_KEY=ntn_...

# --- HQ dashboard ---
HQ_PORT=8099
# Optional shared secret. If set, POSTs to the HQ API need header: Authorization: Bearer <token>
HQ_TOKEN=
# Base URL n8n uses to reach HQ from inside Docker (service name, not localhost)
HQ_URL=http://hq:8099

# --- n8n / Postgres ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me-long-random
POSTGRES_DB=n8n
N8N_ENCRYPTION_KEY=change-me-long-random
GENERIC_TIMEZONE=America/New_York
# Your NAS's Tailscale hostname, used for webhook URLs shown in n8n
N8N_HOST=nas.your-tailnet.ts.net
