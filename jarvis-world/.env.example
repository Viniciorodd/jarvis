# Dev-only: where `npm run dev` (vite) proxies the two backends. Defaults shown.
HQ_TARGET=http://localhost:8099
CP_TARGET=http://localhost:8787

# Optional: override the in-app fetch bases. Normally leave unset — the vite/nginx proxy
# means the app always calls same-origin /hq and /cp, so there is no CORS to configure.
# VITE_HQ_BASE=/hq
# VITE_CP_BASE=/cp
